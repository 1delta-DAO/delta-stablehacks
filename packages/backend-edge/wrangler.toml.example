name = "delta-edge"
main = "src/index.ts"
compatibility_date = "2024-12-01"

# Create KV namespaces with:
#   wrangler kv namespace create AUDIT_KV
#   wrangler kv namespace create WHITELIST_CACHE
# Then paste the generated IDs below.

[[kv_namespaces]]
binding = "AUDIT_KV"
id = "<your-kv-namespace-id>"

[[kv_namespaces]]
binding = "WHITELIST_CACHE"
id = "<your-kv-namespace-id>"

# For local dev, wrangler uses in-memory KV automatically.
# Set SOLANA_RPC_URL as a secret:
#   wrangler secret put SOLANA_RPC_URL

[vars]
SOLANA_RPC_URL = "https://api.devnet.solana.com"
