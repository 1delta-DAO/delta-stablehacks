{
  "name": "frontend-retail",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "tsc -b && vite build",
    "sync-idl": "mkdir -p public/idl && cp ../programs/target/idl/governor.json ../programs/target/idl/delta_mint.json public/idl/",
    "preview": "vite preview --port 3001",
    "faucet:serve": "npx tsx faucet-server.ts",
    "deploy": "pnpm build && npx wrangler pages deploy dist --project-name stablehacks-retail"
  },
  "dependencies": {
    "@civic/solana-gateway-react": "^0.10.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.98.0",
    "buffer": "^6.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rpc-websockets": "^9.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
