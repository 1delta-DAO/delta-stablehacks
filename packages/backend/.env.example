# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ─── Solana ───────────────────────────────────────────────────────────────────
# RPC endpoint — use devnet for local development
SOLANA_RPC_URL=https://api.devnet.solana.com

# delta-mint program ID (matches declare_id! in delta-mint/src/lib.rs)
DELTA_MINT_PROGRAM_ID=3FLEACtqQ2G9h6sc7gLniVfK4maG59Eo4pt8H4A9QggY

# Comma-separated wrapped mint addresses, one per pool (from initialize_pool).
# One KYC approval whitelists the wallet in all listed pools simultaneously.
# Single pool:  WRAPPED_MINT_ADDRESSES=<dUSDY_pubkey>
# Multi pool:   WRAPPED_MINT_ADDRESSES=<dUSDY_pubkey>,<dUSDC_pubkey>
WRAPPED_MINT_ADDRESSES=<your_wrapped_mint_pubkey>

# Admin keypair as a JSON byte array — this keypair is the `authority`
# that signed initialize_mint, so it has permission to call add_to_whitelist.
#
# Generate:  solana-keygen new --outfile admin-keypair.json
# Read key:  cat admin-keypair.json
#
# NEVER commit a real keypair. Fund this keypair on devnet:
#   solana airdrop 2 <pubkey> --url devnet
ADMIN_KEYPAIR_JSON=[12,34,56,...]

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ─── Risk Controls ────────────────────────────────────────────────────────────
# Per-wallet maximum deposit exposure in USD
DEPOSIT_CAP_USD=1000000
# Total pool exposure cap in USD
POOL_CAP_USD=50000000
# Comma-separated mock OFAC/sanctions addresses (blocked at approve time)
OFAC_MOCK_LIST=

# ─── Fireblocks (optional) ────────────────────────────────────────────────────
# Leave blank to use the local admin keypair (ADMIN_KEYPAIR_JSON).
# Set all three to enable Fireblocks MPC signing.
FIREBLOCKS_API_KEY=
FIREBLOCKS_VAULT_ACCOUNT_ID=0
FIREBLOCKS_SIGNER_PUBLIC_KEY=
