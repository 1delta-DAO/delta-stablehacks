{
  "name": "programs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor build -p counter && PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor build -p delta_mint && PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor build -p governor",
    "test": "PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor test",
    "test:fork": "ANCHOR_PROVIDER_URL=https://api.mainnet-beta.solana.com PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor test",
    "test:full-flow": "ANCHOR_PROVIDER_URL=https://api.mainnet-beta.solana.com pnpm ts-mocha -p ./tsconfig.json -t 1000000 tests/kamino-full-flow.fork.ts",
    "test:full-flow:validator": "bash scripts/test-validator-flow.sh",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "deploy:mnemonic": "bash scripts/deploy-mnemonic.sh",
    "deploy:mnemonic:mainnet": "bash scripts/deploy-mnemonic.sh mainnet-beta",
    "deploy:mainnet": "PATH=$HOME/.local/share/solana/install/active_release/bin:$PATH anchor deploy --provider.cluster mainnet",
    "devnet:governor": "npx tsx scripts/deploy-governor-devnet.ts",
    "devnet:oracles": "npx tsx scripts/setup-devnet-oracles.ts",
    "devnet:market": "npx tsx scripts/setup-devnet-market.ts",
    "devnet:full": "pnpm devnet:oracles && pnpm devnet:governor && pnpm devnet:market",
    "devnet:complete": "npx tsx scripts/complete-devnet-setup.ts",
    "deploy:all": "bash scripts/deploy-all.sh",
    "deploy:all:devnet": "bash scripts/deploy-all.sh devnet",
    "deploy:all:mainnet": "bash scripts/deploy-all.sh mainnet-beta",
    "fetch:tokens": "npx tsx scripts/fetch-token-list.ts",
    "whitelist": "npx tsx scripts/whitelist-wallet.ts",
    "add-admin": "npx tsx scripts/add-admin.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@kamino-finance/klend-sdk": "^7.3.20",
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.5.0",
    "anchor-bankrun": "^0.5.0",
    "bip39": "^3.1.0",
    "chai": "^4.4.0",
    "ed25519-hd-key": "^1.3.0",
    "mocha": "^10.7.0",
    "solana-bankrun": "^0.4.0",
    "ts-mocha": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
